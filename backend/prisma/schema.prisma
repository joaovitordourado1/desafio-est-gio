generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  CHECKING
  SAVINGS
}

model Account {
  id           String      @id @default(uuid()) @db.Uuid
  name         String
  type         AccountType
  balanceCents Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}